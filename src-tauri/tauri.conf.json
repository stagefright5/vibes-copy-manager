{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibes Copy Manager",
  "version": "1.0.0",
  "identifier": "com.vibes.vcm",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vibes Copy Manager",
        "width": 420,
        "height": 520,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "shortDescription": "Fast clipboard manager with history, search, and pinning",
    "longDescription": "Vibes Copy Manager (vcm) is a fast, cross-platform clipboard manager built with Tauri. Features clipboard history, instant search, pinned items, image preview, configurable shortcuts, CLI support, and system tray integration."
  }
}
